{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mmdemirbas/mesh/internal/config/config",
  "$defs": {
    "AuthCfg": {
      "properties": {
        "agent": {
          "type": "boolean"
        },
        "key": {
          "type": "string"
        },
        "password_command": {
          "type": "string"
        },
        "known_hosts": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ClipsyncCfg": {
      "properties": {
        "bind": {
          "type": "string"
        },
        "lan_discovery_group": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "static_peers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "poll_interval": {
          "type": "string"
        },
        "file_copy": {
          "type": "boolean"
        },
        "max_file_copy_size": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "bind"
      ]
    },
    "Config": {
      "properties": {
        "listeners": {
          "items": {
            "$ref": "#/$defs/Listener"
          },
          "type": "array"
        },
        "connections": {
          "items": {
            "$ref": "#/$defs/Connection"
          },
          "type": "array"
        },
        "clipsync": {
          "items": {
            "$ref": "#/$defs/ClipsyncCfg"
          },
          "type": "array"
        },
        "filesync": {
          "items": {
            "$ref": "#/$defs/FilesyncCfg"
          },
          "type": "array"
        },
        "gateway": {
          "items": {
            "$ref": "#/$defs/GatewayCfg"
          },
          "type": "array"
        },
        "log_level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "admin_addr": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Connection": {
      "properties": {
        "name": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "failover",
            "multiplex"
          ]
        },
        "targets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "retry": {
          "type": "string"
        },
        "auth": {
          "$ref": "#/$defs/AuthCfg"
        },
        "options": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "forwards": {
          "items": {
            "$ref": "#/$defs/ForwardSet"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "targets"
      ]
    },
    "FilesyncCfg": {
      "properties": {
        "bind": {
          "type": "string"
        },
        "peers": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        },
        "defaults": {
          "$ref": "#/$defs/FilesyncDefaults"
        },
        "folders": {
          "additionalProperties": {
            "$ref": "#/$defs/FolderCfgRaw"
          },
          "type": "object"
        },
        "scan_interval": {
          "type": "string"
        },
        "max_concurrent": {
          "type": "integer"
        },
        "max_bandwidth": {
          "type": "string"
        },
        "max_watches": {
          "type": "integer",
          "description": "Maximum fsnotify watches across all folders. 0 means default (4096)."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "bind",
        "folders"
      ]
    },
    "FilesyncDefaults": {
      "properties": {
        "peers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "direction": {
          "type": "string",
          "enum": ["send-receive", "send-only", "receive-only", "dry-run", "disabled"],
          "description": "Sync direction. receive-only applies remote deletes (files deleted on sender are deleted locally)."
        },
        "ignore_patterns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "max_files": {
          "type": "integer",
          "description": "Maximum tracked files. 0 means use the runtime default (500,000)."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "FolderCfgRaw": {
      "properties": {
        "path": {
          "type": "string"
        },
        "peers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "direction": {
          "type": "string",
          "enum": ["send-receive", "send-only", "receive-only", "dry-run", "disabled"],
          "description": "Sync direction. receive-only applies remote deletes (files deleted on sender are deleted locally)."
        },
        "ignore_patterns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "max_files": {
          "type": "integer",
          "description": "Maximum tracked files. 0 means use the runtime default (500,000)."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "path"
      ]
    },
    "Forward": {
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "forward",
            "socks",
            "http"
          ]
        },
        "bind": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "bind"
      ]
    },
    "ForwardSet": {
      "properties": {
        "name": {
          "type": "string"
        },
        "options": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "remote": {
          "items": {
            "$ref": "#/$defs/Forward"
          },
          "type": "array"
        },
        "local": {
          "items": {
            "$ref": "#/$defs/Forward"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name"
      ]
    },
    "GatewayCfg": {
      "properties": {
        "name": {
          "type": "string"
        },
        "log": {
          "$ref": "#/$defs/LogCfg"
        },
        "client": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GatewayClientCfg"
          }
        },
        "routing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GatewayRoutingRule"
          }
        },
        "upstream": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GatewayUpstreamCfg"
          }
        },
        "response_model": {
          "type": "string",
          "description": "Optional. When set, the gateway replaces the model name in every client-facing response (non-streaming, SSE, passthrough) with this value before forwarding it to the client. Empty (default) preserves the existing behavior of echoing the original client model. Useful for visually distinguishing gateway-routed sessions from direct sessions in the LLM client UI. (PLAN_GATEWAY_SEPARATION Part 1.)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "client",
        "routing",
        "upstream"
      ]
    },
    "GatewayClientCfg": {
      "properties": {
        "bind": {
          "type": "string"
        },
        "api": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "bind",
        "api"
      ]
    },
    "GatewayRoutingRule": {
      "properties": {
        "upstream_name": {
          "type": "string"
        },
        "client_model": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "upstream_name",
        "client_model"
      ]
    },
    "GatewayUpstreamCfg": {
      "properties": {
        "name": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "api": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai"
          ]
        },
        "api_key_env": {
          "type": "string"
        },
        "proxy": {
          "type": "string"
        },
        "timeout": {
          "type": "string"
        },
        "default_max_tokens": {
          "type": "integer"
        },
        "context_window": {
          "type": "integer"
        },
        "summarizer": {
          "type": "string"
        },
        "model_map": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "target",
        "api"
      ]
    },
    "Listener": {
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "socks",
            "http",
            "relay",
            "sshd"
          ]
        },
        "bind": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "host_key": {
          "type": "string"
        },
        "authorized_keys": {
          "type": "string"
        },
        "shell": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "accept_env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "banner": {
          "type": "string"
        },
        "motd": {
          "type": "string"
        },
        "sftp_enabled": {
          "type": "boolean"
        },
        "sftp_root": {
          "type": "string"
        },
        "allow_agent_forwarding": {
          "type": "boolean"
        },
        "options": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "bind"
      ]
    },
    "LogCfg": {
      "properties": {
        "level": {
          "type": "string"
        },
        "dir": {
          "type": "string"
        },
        "max_file_size": {
          "type": "string"
        },
        "max_age": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "additionalProperties": {
    "$ref": "#/$defs/Config"
  },
  "type": "object"
}
